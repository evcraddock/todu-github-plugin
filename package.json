{
  "name": "todu-github-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "A todu plugin that syncs GitHub issues to the todu system.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && esbuild src/index.ts --bundle --format=esm --platform=node --outfile=dist/index.js --packages=bundle",
    "build:watch": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm test",
    "pre-pr": "./scripts/pre-pr.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@todu/core": "^0.9.0"
  }
}
